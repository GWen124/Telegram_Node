const fs = require('fs');
const net = require('net');

// ==========================================
// ⚙️ 1. 抓取源（增加到了 10 个以上，确保基数）
// ==========================================
const CHANNELS = [
    'https://t.me/s/v2ray_free_vpn', 'https://t.me/s/free8964', 'https://t.me/s/Clash_VPNS',
    'https://t.me/s/v2ray_nodes', 'https://t.me/s/daily_proxies', 'https://t.me/s/freeVPNjd',
    'https://t.me/s/v2free666', 'https://t.me/s/Outline_Vpn', 'https://t.me/s/Jichangdog',
    'https://t.me/s/ssrList', 'https://t.me/s/v2ray_repo'
];

const TCP_TIMEOUT = 3500; 
const RENAME_PREFIX = "Telegram｜"; 

// 你的标签字典
const tagDict = { "Zx": "专线", "IPLC": "IPLC", "IEPL": "IEPL", "Fam": "家宽", "直连": "直连", "中转": "中转", "Netflix": "Netflix", "OpenAI": "OpenAI" };
const sortedTagKeys = Object.keys(tagDict).sort((a, b) => b.length - a.length);

const countryMap = [
    { keys: /香港|港|HK/i, flag: '🇭🇰', name: '香港' },
    { keys: /台湾|台|TW/i, flag: '🇨🇳', name: '台湾' },
    { keys: /日本|日|JP/i, flag: '🇯🇵', name: '日本' },
    { keys: /美国|美|US/i, flag: '🇺🇸', name: '美国' },
    { keys: /新加坡|新|SG/i, flag: '🇸🇬', name: '新加坡' }
];

// ==========================================
// 🔌 2. 核心逻辑
// ==========================================

async function fetchNodes() {
    let allUris = [];
    for (const url of CHANNELS) {
        try {
            const res = await fetch(url);
            const text = await res.text();
            // 改进的正则：支持 ss, vmess, vless, trojan
            const matches = text.match(/(ss|vmess|vless|trojan):\/\/[a-zA-Z0-9%?#=&.@\-\/\[\]:]+/g) || [];
            console.log(`📡 频道 [${url.split('/').pop()}] 抓取到: ${matches.length} 个原始节点`);
            allUris.push(...matches);
        } catch (e) { console.log(`❌ 无法访问频道: ${url}`); }
    }
    return [...new Set(allUris)]; // 去重
}

function ping(host, port) {
    return new Promise((resolve) => {
        const socket = new net.Socket();
        socket.setTimeout(TCP_TIMEOUT);
        socket.on('connect', () => { socket.destroy(); resolve(true); });
        socket.on('error', () => { socket.destroy(); resolve(false); });
        socket.on('timeout', () => { socket.destroy(); resolve(false); });
        socket.connect(port, host);
    });
}

// 解析节点（简单处理，确保不报错）
function parse(uri) {
    let name = "Unknown", server = "", port = 0;
    try {
        if (uri.startsWith('vmess://')) {
            const b = JSON.parse(Buffer.from(uri.slice(8), 'base64').toString());
            name = b.ps; server = b.add; port = b.port;
        } else {
            const match = uri.match(/@([^:]+):(\d+)/);
            if (match) { server = match[1]; port = match[2]; }
            name = decodeURIComponent(uri.split('#')[1] || "Unknown");
        }
    } catch(e) {}
    return { uri, name, server, port };
}

async function main() {
    const rawUris = await fetchNodes();
    console.log(`📊 总计去重后节点数: ${rawUris.length}`);

    const parsed = rawUris.map(parse).filter(n => n.server && n.port);
    const aliveNodes = [];

    console.log(`⚡ 开始并发测速 (Timeout: ${TCP_TIMEOUT}ms)...`);
    
    // 分批测速，防止 GitHub 封锁
    for (let i = 0; i < parsed.length; i += 50) {
        const batch = parsed.slice(i, i + 50);
        await Promise.all(batch.map(async (n) => {
            const isOk = await ping(n.server, n.port);
            if (isOk) aliveNodes.push(n);
        }));
    }

    console.log(`✅ 测速完成，存活节点: ${aliveNodes.length}`);

    // --- 应急预案：如果测速全灭，强行保留前 10 个原始节点，防止输出为空 ---
    const finalSelection = aliveNodes.length > 0 ? aliveNodes : parsed.slice(0, 10);
    if (aliveNodes.length === 0) console.log("⚠️ 测速全灭，已触发保底机制（强行提取前 10 个节点）");

    // --- 你的重命名逻辑 ---
    let output = [];
    let grouped = {};

    finalSelection.forEach(n => {
        let nodeData = { ...n, cFlag: '🏴', cName: '未知', tags: [] };
        for (let c of countryMap) { if (c.keys.test(n.name)) { nodeData.cFlag = c.flag; nodeData.cName = c.name; break; } }
        
        // 归类
        if (!grouped[nodeData.cName]) grouped[nodeData.cName] = [];
        grouped[nodeData.cName].push(nodeData);
    });

    Object.keys(grouped).forEach(region => {
        grouped[region].forEach((item, idx) => {
            let seq = (idx + 1).toString().padStart(2, '0');
            let newName = `${RENAME_PREFIX}${item.cFlag} ${region} ${seq}`;
            
            // 重新包装 URI
            if (item.uri.startsWith('vmess://')) {
                let b = JSON.parse(Buffer.from(item.uri.slice(8), 'base64').toString());
                b.ps = newName;
                output.push('vmess://' + Buffer.from(JSON.stringify(b)).toString('base64'));
            } else {
                output.push(item.uri.split('#')[0] + '#' + encodeURIComponent(newName));
            }
        });
    });

    fs.writeFileSync('sub.txt', Buffer.from(output.join('\n')).toString('base64'));
    console.log(`🎉 处理完毕，sub.txt 大小: ${output.length} 节点`);
}

main();
